{
  "name": "tokyo-nextjs",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.14.0",
  "engines": {
    "node": "^22.12.0 || ^24.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "seed:cv": "tsx scripts/seed-cv.ts",
    "db:seed": "dotenv -e .env.local -- tsx seed/index.ts",
    "db:seed:force": "dotenv -e .env.local -- tsx seed/index.ts --force",
    "db:seed:albums": "dotenv -e .env.local -- tsx seed/index.ts --only=albums",
    "db:seed:videos": "dotenv -e .env.local -- tsx seed/index.ts --only=videos",
    "db:seed:services": "dotenv -e .env.local -- tsx seed/index.ts --only=services",
    "db:seed:resume": "dotenv -e .env.local -- tsx seed/index.ts --only=resume_entries",
    "db:seed:settings": "dotenv -e .env.local -- tsx seed/index.ts --only=site_settings",
    "db:seed:users": "dotenv -e .env.local -- tsx seed/index.ts --only=users",
    "db:backup": "dotenv -e .env.local -- tsx seed/backup.ts",
    "db:backup:overwrite": "dotenv -e .env.local -- tsx seed/backup.ts --overwrite",
    "db:clean": "dotenv -e .env.local -- tsx seed/clean.ts",
    "db:clean:yes": "dotenv -e .env.local -- tsx seed/clean.ts --yes",
    "db:reset": "dotenv -e .env.local -- tsx seed/backup.ts && dotenv -e .env.local -- prisma migrate reset --force",
    "db:reset:seed": "dotenv -e .env.local -- tsx seed/backup.ts && dotenv -e .env.local -- prisma migrate reset --force && dotenv -e .env.local -- tsx seed/index.ts",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:migrate:deploy": "dotenv -e .env.local -- prisma migrate deploy",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "db:seed:prod": "tsx scripts/db/seed-prod.ts",
    "db:migrate:prod": "tsx scripts/db/migrate-prod.ts",
    "db:status:prod": "tsx scripts/db/status-prod.ts",
    "vercel-build": "node scripts/vercel-build.js",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css,scss}": [
      "prettier --write"
    ],
    "prisma/schema.prisma": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-avatar": "^1.2.2",
    "@radix-ui/react-checkbox": "^1.3.7",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-progress": "^1.1.12",
    "@radix-ui/react-radio-group": "^1.4.3",
    "@radix-ui/react-select": "^2.3.3",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-toast": "^1.2.19",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@react-pdf/renderer": "^4.5.1",
    "@tiptap/extension-link": "^3.27.3",
    "@tiptap/extension-placeholder": "^3.27.3",
    "@tiptap/react": "^3.27.3",
    "@tiptap/starter-kit": "^3.27.3",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/blob": "^2.6.1",
    "@vercel/speed-insights": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "better-auth": "^1.6.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "eslint-config-next": "^16.2.10",
    "framer-motion": "^12.42.2",
    "lucide-react": "^0.554.0",
    "next": "16.2.10",
    "next-intl": "^4.13.2",
    "next-themes": "^0.4.6",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-dropzone": "^17.0.0",
    "react-hook-form": "^7.81.0",
    "react-toastify": "^11.1.0",
    "tailwind-merge": "^3.6.0",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@tailwindcss/typography": "^0.5.20",
    "@types/node": "24.10.1",
    "@types/pg": "^8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "postcss": "^8.5.18",
    "prettier": "^3.9.5",
    "prettier-plugin-prisma": "^5.0.0",
    "prisma": "^7.8.0",
    "tailwindcss": "^4.3.2",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.23.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.63.0"
  }
}
